{
  "name": "zippy",
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "echo 'Run ./tilt_up.sh (not tilt up) — Tilt owns dev servers, not Nx. See docs/nx.md for the Tilt-vs-Nx split.'",
    "graph": "nx graph",
    "check": "nx run-many -t typecheck lint test",
    "typecheck": "nx run-many -t typecheck",
    "lint": "oxlint",
    "lint:boundaries": "bunx nx run-many -t lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "affected": "nx affected -t lint typecheck build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@nx/js": "^23.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-oxlint": "1.73.0",
    "lefthook": "^2.1.9",
    "nx": "^23.0.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "bun@1.3.12"
}

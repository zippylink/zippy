# Copy to .env.local and fill in. Never commit real secrets.
#
# A fresh clone BOOTS ON AN EMPTY FILE: every paid integration is env-gated to a
# silent no-op (no key → feature off, app still runs). Fill keys only when you
# want that feature. Fill order + where to get each key: docs/stack/getting-started.md.
# What any of it costs: docs/stack/costs.md.
#
# ── boots with ZERO keys ────────────────────────────────────────────────────
#   DATABASE_URL (has a local default) · all the URLs below · Microsoft Clarity
# ── needed to actually … ────────────────────────────────────────────────────
#   log in          → BETTER_AUTH_SECRET
#   call AI          → AI_API_KEY   (NO free tier — pay from token 1)
#   send email       → RESEND_API_KEY
#   take payment     → CREEM_API_KEY / CREEM_WEBHOOK_SECRET
#   see analytics    → NEXT_PUBLIC_POSTHOG_KEY / POSTHOG_API_KEY
# ─────────────────────────────────────────────────────────────────────────────

# libs/db — Postgres (Drizzle)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/builders_stack

# libs/ai — your model provider. @stack/ai defaults to DEFAULT_PROVIDER=openai,
# so AI_API_KEY must be an OPENAI key (sk-…) unless you change the provider in
# libs/ai/src/providers.ts. NO free tier — you pay from the first token. See docs/stack/ai.md.
AI_API_KEY=                               # OpenAI key (sk-…) for the default provider

# services/payment — Merchant of Record. Adapter ships; drop a key to go live.
# Provider resolves in this order: PAYMENT_PROVIDER selector → whichever *_API_KEY
# is set → Mock (boots keyless). Adding/swapping a vendor: docs/stack/payments.md.
# PAYMENT_PROVIDER=creem                    # optional: creem | dodo | mock (else auto-detect by key)
# Creem
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
# Dodo Payments (second MoR — starter skeleton, wire up before going live). https://docs.dodopayments.com
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=

# services/api
# No pinned PORT: portless injects one in local dev and proxies the stable URL
# (api.stack.localhost:1355) to it. Services fall back to 3001/3002 when run
# standalone. See docs/portless.md.
WEB_ORIGIN=http://web.stack.localhost:1355

# Better Auth (services/api + libs/auth) — REQUIRED at runtime for login to work
BETTER_AUTH_SECRET=                       # generate: openssl rand -base64 32
BETTER_AUTH_URL=http://api.stack.localhost:1355
# BETTER_AUTH_TRUSTED_ORIGINS=http://web.stack.localhost:1355   # comma-separated; defaults to the web app

# apps/web → services/api (both server + browser fetches). The Tiltfile injects
# these for `./tilt_up.sh`; set them here for standalone `bun --filter @stack/web dev`.
NEXT_PUBLIC_API_URL=http://api.stack.localhost:1355
API_URL=http://api.stack.localhost:1355
# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET  — optional, for social login

# apps/landing → apps/web. Points the marketing site's "Log in / Get started"
# at the web app. The Tiltfile injects it for `./tilt_up.sh`; set it for standalone
# `bun --filter @stack/landing dev`.
NEXT_PUBLIC_APP_URL=http://web.stack.localhost:1355

# libs/email — Resend (transactional + drip email). See docs/stack/email.md.
# Unset RESEND_API_KEY = every send is logged + skipped (no-op), app still boots.
RESEND_API_KEY=                           # https://resend.com/api-keys
EMAIL_FROM=onboarding@resend.dev          # verified sender; Resend's shared test sender works out of the box

# Analytics — PostHog (product analytics + session replay + error tracking). See docs/stack/analytics.md.
# Client keys (apps/web, via @stack/analytics) — unset = analytics/replay/errors OFF, app renders normally.
NEXT_PUBLIC_POSTHOG_KEY=                   # project API key (phc_…)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # EU region: https://eu.i.posthog.com
# Server key (services/api + libs/auth signup hook, via posthog-node) — same project key.
POSTHOG_API_KEY=                           # phc_… (or a dedicated server key)
# POSTHOG_HOST=https://us.i.posthog.com    # server host override; defaults to US

# Analytics — Microsoft Clarity (session recording). Client-only (apps/web, via @stack/analytics).
NEXT_PUBLIC_CLARITY_ID=                    # Clarity project id; unset = Clarity OFF

# Monitoring — Better Stack (uptime + logs). Uptime monitors on /health need NO key (external
# HTTP checks). This token is only for the in-app log drain (@stack/observability → services'
# error paths). Unset = stdout only, no external drain. See docs/monitoring.md.
BETTERSTACK_SOURCE_TOKEN=                   # Better Stack Logs source token; unset = drain OFF
# BETTERSTACK_INGEST_HOST=https://in.logs.betterstack.com   # override if your source's host differs

# Agent tooling (MCP) — used by agents/mcp.json when copied to .mcp.json.
# context7 (up-to-date library docs) works KEYLESS at a lower rate limit; add a
# key to raise it. The postgres MCP reuses DATABASE_URL above (needs `uv` for uvx).
CONTEXT7_API_KEY=                          # optional — https://context7.com

# ── Deploy (optional — NOT needed to boot; see docs/deploy.md + docs/secrets.md) ──
# The code doesn't read these; they live in your CI/deploy environment, not here.
# Prod/preview DB: point DATABASE_URL (above) at your Neon connection string.
# Cloudflare (wrangler deploy — dashboard → Account ID / API Tokens):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=                     # token with Workers edit permissions
# Infisical machine identity (team/CI secret injection — `infisical run`):
# INFISICAL_PROJECT_ID=
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=

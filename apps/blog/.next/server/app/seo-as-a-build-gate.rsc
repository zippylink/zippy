16:["$","p",null,{"className":"my-4 leading-7 text-foreground/90","children":["Here is the part the tooling can't do for you, and pretending otherwise is where most\n\"GEO\" advice goes wrong: ",["$","strong",null,{"children":"the lever that gets you surfaced and cited is original,\nfirst-hand, expert content with a point of view."}]," Google says this plainly — there is\nno special schema, no magic file, no phrasing trick that substitutes for having\nsomething worth reading on a crawlable page."]}]
17:["$","p",null,{"className":"my-4 leading-7 text-foreground/90","children":["So the guide is blunt about what ",["$","em",null,{"children":"not"}]," to do, and we put the same list in ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"AGENTS.md"}],":"]}]
18:["$","ul",null,{"className":"my-4 list-disc space-y-2 pl-6 text-foreground/90","children":["\n",["$","li",null,{"className":"leading-7","children":["Don't ",["$","strong",null,{"children":"chunk"}]," your writing into bite-size fragments \"for the AI\". Write sections and\nparagraphs because humans read that way — that's readability, not an AI format."]}],"\n",["$","li",null,{"className":"leading-7","children":["Don't write in ",["$","strong",null,{"children":"\"AI syntax\""}],". There isn't one."]}],"\n",["$","li",null,{"className":"leading-7","children":["Don't mass-produce ",["$","strong",null,{"children":"scaled, recycled, or commodity"}]," content, or spin a page per\nkeyword variation."]}],"\n",["$","li",null,{"className":"leading-7","children":["Don't treat ",["$","strong",null,{"children":["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"llms.txt"}]}]," as a ranking lever. Google Search ignores it — it \"will\nneither harm nor help\" your visibility. We still ship one for the non-Google tools\nthat read it, but we're honest that it's not why anyone finds us."]}],"\n"]}]
